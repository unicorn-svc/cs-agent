# Groq API 인증 키 (필수)
GROQ_API_KEY=gsk_your_groq_api_key_here

# 서비스 API 인증 키
API_KEY=your_service_api_key_here

# ChromaDB 설정
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# PostgreSQL 연결 문자열
POSTGRES_DSN=postgresql://csagent:csagent@localhost:5432/csagent

# 상담원 업무 시스템 API URL
AGENT_SYSTEM_API_URL=http://localhost:9000/api/v1

# 알림 Webhook URL
NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# 임계값 설정
AUTO_RATE_ALERT_THRESHOLD=60
FAQ_SCORE_THRESHOLD=75
MAX_SEARCH_ATTEMPTS=3

# 서버 설정
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# Mock 모드 (true: Mock 사용, false: Real 연동)
USE_MOCK=true
