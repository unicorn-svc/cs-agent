# API Configuration
API_KEY=sk-test-key
API_HOST=0.0.0.0
API_PORT=8000

# LLM Configuration (Groq)
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=512
GROQ_TIMEOUT=30

# Vector DB Configuration (ChromaDB)
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_COLLECTION=faq

# Database Configuration
POSTGRES_DSN=sqlite:///./test.db
POSTGRES_ECHO=false

# External System Integration
AGENT_SYSTEM_API_URL=http://agent-system:8080
AGENT_SYSTEM_API_TIMEOUT=10

# Notification
NOTIFY_WEBHOOK_URL=

# Thresholds
AUTO_RATE_ALERT_THRESHOLD=60.0
FAQ_SCORE_THRESHOLD=75.0
MAX_SEARCH_ATTEMPTS=3
RELEVANCE_SCORE_THRESHOLD=90.0

# Cost
COST_PER_AUTO_HANDLING=28000

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
